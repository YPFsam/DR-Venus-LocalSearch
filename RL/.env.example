# Copy this file to .env and edit the absolute model path before training.

# Official SFT checkpoint downloaded from:
# https://huggingface.co/inclusionAI/DR-Venus-4B-SFT
MODEL_PATH=/absolute/path/to/DR-Venus-4B-SFT

# Four-GPU local RL defaults
NUM_GPUS=4
TRAIN_FILE=data/redsearcher_rl_1k.parquet
VAL_FILE=data/test.parquet
EXPECTED_TRAIN_ROWS=1000
OUTPUT=./output
EVAL_LOG_PATH=./eval_log
PROJECT_NAME=dr-venus-local-rl
EXPERIMENT_NAME=dr-venus-4b-local-search-4gpu
LOGGER_BACKENDS="['console','tensorboard']"

# Checkpointing and resume. Keep the same OUTPUT directory when resuming.
SAVE_FREQ=5
RESUME_MODE=auto
MAX_ACTOR_CKPT_TO_KEEP=2
MAX_CRITIC_CKPT_TO_KEEP=2
MAX_LOCAL_CKPT_TO_KEEP=2
# RESUME_FROM_PATH=./output/global_step_5

# Local retrieval service. Tantivy uses an inverted index and is the default.
USE_LOCAL_SEARCH=true
LOCAL_SEARCH_SERVER_URL=http://localhost:8890
LOCAL_SEARCH_TOPK=10
LOCAL_SEARCH_BACKEND=tantivy
LOCAL_SEARCH_LOG_FILE=./logs/local_search.log
# LOCAL_SEARCH_LOG_QUERIES=true
NO_PROXY=localhost,127.0.0.1
no_proxy=localhost,127.0.0.1

# Offline reward configuration. No external judge API is required.
TRAIN_REWARD_TYPE=f1
VALID_REWARD_TYPE=f1_em_noformatf1

# Conservative first-run value for 80 GB cards. Increase only after a smoke run.
GPU_MEMORY_UTILIZATION=0.80

# Optional smoke-test overrides:
# TOTAL_TRAINING_STEPS=1
# MAX_TURNS=5
# TRACE_SAVE_INTERVAL=10
# TRACE_MAX_SAMPLES=8
# DEBUG_SHELL=true

# Original DR-Venus disables Ray's host-memory monitor. Set 250 temporarily
# while diagnosing CPU RAM or cgroup OOM pressure during checkpoint saves.
# RAY_MEMORY_MONITOR_REFRESH_MS=250

# Optional distributed NIC override:
# GLOO_SOCKET_IFNAME=eth0

# Optional W&B experiment tracking. Put the real key in .env only.
# WANDB_API_KEY=replace-with-a-dedicated-api-key
# WANDB_ENTITY=your-team-or-user
# WANDB_RUN_ID=dr-venus-4b-local-search-4gpu
# WANDB_RESUME=allow
